# GitHub OAuth Configuration (Optional - for production deployment)
# MDSG comes with a default OAuth app for development and testing
# For production deployment, create your own OAuth app at:
# https://github.com/settings/applications/new

# Production OAuth credentials (optional)
# GITHUB_CLIENT_ID=your_production_client_id_here
# GITHUB_CLIENT_SECRET=your_production_client_secret_here

# Server Configuration
PORT=3001
NODE_ENV=development

# Production deployment URLs
# For production, set your GitHub OAuth app callback URL to:
# https://your-domain.com
